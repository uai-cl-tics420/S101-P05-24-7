# ══════════════════════════════════════════════════════
#  Loombox — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════

# ── NextAuth ───────────────────────────────────────────
# Public URL of the app (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Random secret (min 32 chars). Generate with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here-min-32-chars

# ── Google OAuth ───────────────────────────────────────
# Create credentials at: https://console.cloud.google.com/
# App type: Web application
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Database (PostgreSQL via Prisma) ───────────────────
# Pooled connection (used by Prisma at runtime)
DATABASE_URL=postgresql://user:password@localhost:5432/loombox_db

# Direct connection (used by Prisma for migrations)
DIRECT_URL=postgresql://user:password@localhost:5432/loombox_db

# ── Email / SMTP (optional — for magic link / OTP) ─────
# Example using Resend SMTP:
#   EMAIL_SERVER=smtp://resend:<api-key>@smtp.resend.com:465
EMAIL_SERVER=smtp://user:password@smtp.example.com:587
EMAIL_FROM=noreply@example.com
