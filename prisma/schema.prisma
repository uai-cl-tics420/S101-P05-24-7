// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model with role support (CONSERJE or RESIDENTE)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(RESIDENTE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  apartmentId   String?
  apartment     Apartment? @relation(fields: [apartmentId], references: [id])
  onboardingComplete Boolean @default(false)
  totpSecret         String?
  totpEnabled        Boolean @default(false)

  accounts           Account[]
  sessions           Session[]
  registeredPackages Package[]      @relation("RegisteredPackages")
  pickedUpPackages   Package[]      @relation("PickedUpPackages")
  packageEvents      PackageEvent[] @relation("PackageEvents")
  pushSubscriptions  PushSubscription[]
  trustedDevices     TrustedDevice[]
  otpSessions        OtpSession[]
}

enum UserRole {
  CONSERJE
  RESIDENTE
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier  String
  token       String   @unique
  expires     DateTime
  attempts    Int      @default(0)
  lockedUntil DateTime?

  @@unique([identifier, token])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OtpSession {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Business Models ────────────────────────────────────────────────────────

model Apartment {
  id        String   @id @default(cuid())
  number    String
  tower     String?
  floor     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  packages Package[]
  residents User[]

  @@unique([number, tower])
  @@index([number])
}

model Package {
  id            String        @id @default(cuid())
  trackingCode  String        @unique
  status        PackageStatus @default(PENDING)

  // Package details
  description   String?
  carrier       String?       // Courier company: Chilexpress, DHL, Correos, etc.
  recipientName String?       // Name of the resident the package is for
  receiverName  String?       // Name of the person who physically picked up the package
  imageUrl      String?       // Optional photo taken at reception
  isPerishable  Boolean       @default(false) // For urgent notifications (Ticket #25)

  // Timestamps
  receivedAt    DateTime      @default(now())
  notifiedAt    DateTime?     // When push notification was sent to resident
  pickedUpAt    DateTime?     // When the resident picked up the package
  deliveredAt   DateTime?     // Alias kept for backward-compatibility
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  apartmentId    String
  apartment      Apartment @relation(fields: [apartmentId], references: [id])

  registeredById String
  registeredBy   User      @relation("RegisteredPackages", fields: [registeredById], references: [id])

  pickedUpById   String?
  pickedUpBy     User?     @relation("PickedUpPackages", fields: [pickedUpById], references: [id])

  events PackageEvent[]

  @@index([apartmentId])
  @@index([registeredById])
  @@index([pickedUpById])
  @@index([status])
  @@index([receivedAt])
}

// Full audit trail: every state change is recorded as an event
model PackageEvent {
  id        String           @id @default(cuid())
  type      PackageEventType
  notes     String?
  createdAt DateTime         @default(now())

  packageId   String
  package     Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  createdById String
  createdBy   User    @relation("PackageEvents", fields: [createdById], references: [id])

  @@index([packageId])
  @@index([createdById])
}

enum PackageStatus {
  PENDING    // Received, resident not yet notified
  NOTIFIED   // Push notification sent to resident
  DELIVERED  // Picked up by resident or authorized person
}

enum PackageEventType {
  RECEIVED   // Package arrived and was registered
  NOTIFIED   // Resident was notified
  PICKED_UP  // Package was picked up
  RETURNED   // Package was returned to sender
  NOTE_ADDED // A note was added manually
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
}

